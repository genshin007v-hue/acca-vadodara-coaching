          </label>
        </div>
        <button className="btn" type="submit">Create</button>
      </form>}

      {mode === 'student' && <div>
        {!user ? <div className="muted">Login first to access the student dashboard.</div> : <>
          <h2>Student Dashboard</h2>
          <div className="grid two">
            <div className="course">
              <strong>Welcome, {user.name}</strong>
              <div className="muted">This is your dashboard shell. It can later include notes, timetable, fees, tests, and progress.</div>
            </div>
            <div className="course">
              <strong>Quick actions</strong>
              <div className="muted">Use the Online Test tab, upload documents, or open WhatsApp for support.</div>
            </div>
          </div>
          <div style={{marginTop:16}}>
            <a className="btn2" href={whatsappLink} target="_blank">Message on WhatsApp</a>
          </div>
        </>}
      </div>}

      {mode === 'admin' && <div>
        {!user ? <div className="muted">Login first to access the admin panel.</div> : user.role !== 'admin' ? <div className="muted">Admin access only.</div> : <>
          <h2>Admin Panel</h2>
          <div className="grid two">
            <form className="course" onSubmit={saveReceipt}>
              <h3>Generate receipt</h3>
              <label className="label">Student name<input className="input" value={receiptForm.studentName} onChange={e => setReceiptForm({...receiptForm, studentName:e.target.value})} /></label>
              <label className="label">Amount<input className="input" value={receiptForm.amount} onChange={e => setReceiptForm({...receiptForm, amount:e.target.value})} /></label>
              <label className="label">Mode<select className="select" value={receiptForm.mode} onChange={e => setReceiptForm({...receiptForm, mode:e.target.value})}><option>Cash</option><option>UPI</option><option>Bank</option></select></label>
              <label className="label">Note<input className="input" value={receiptForm.note} onChange={e => setReceiptForm({...receiptForm, note:e.target.value})} /></label>
              <button className="btn" type="submit">Save receipt</button>
            </form>
            <div className="course">
              <h3>Upload file</h3>
              <input className="input" type="file" onChange={e => uploadFile(e.target.files[0])} />
              <div className="muted" style={{marginTop:10}}>{uploadMsg}</div>
              <div style={{marginTop:16}}>
                <strong>Receipt/storage preview</strong>
                <div className="muted">Receipts and uploads are listed below once saved.</div>
              </div>
            </div>
          </div>
          <div style={{marginTop:18, overflowX:'auto'}}>
            <h3>Students</h3>
            <table className="table">
              <thead><tr><th>Name</th><th>Course</th><th>Batch</th><th>Fees</th><th>Progress</th></tr></thead>
              <tbody>{adminData.students.map(s => <tr key={s.id}><td>{s.name}</td><td>{s.course}</td><td>{s.batch}</td><td>{s.feesStatus}</td><td>{s.progress}%</td></tr>)}</tbody>
            </table>
          </div>
          <div className="grid two" style={{marginTop:18}}>
            <div>
              <h3>Receipts</h3>
              {adminData.receipts.map(r => <div className="course" key={r.id}><strong>{r.receiptNo}</strong><div className="muted">{r.studentName} • {r.amount} • {r.mode}</div></div>)}
            </div>
            <div>
              <h3>Uploads</h3>
              {adminData.uploads.map(u => <div className="course" key={u.id}><strong>{u.originalName}</strong><div className="muted">{u.mimeType} • {Math.round(u.size/1024)} KB</div></div>)}
            </div>
          </div>
        </>}
      </div>}

      {mode === 'test' && <div>
        {!user ? <div className="muted">Login first to access the test system.</div> : <>
          <h2>Online Test System</h2>
          <div className="muted">A simple CBT-style demo with MCQ and numeric input.</div>
          {testQ.map(q => <div className="question" key={q.id}>
            <strong>{q.question}</strong>
            {q.type === 'mcq' ? q.options.map((opt, idx) => <label key={idx} className="option">
              <input type="radio" name={'q'+q.id} onChange={() => setAnswers({...answers, [q.id]: idx})} /> {opt}
            </label>) : <input className="input" type="number" placeholder="Type answer" onChange={e => setAnswers({...answers, [q.id]: e.target.value})} />}
          </div>)}
          <button className="btn" onClick={submitTest}>Submit Test</button>
          {testResult && <div className="course" style={{marginTop:16}}>
            <strong>Score: {testResult.score}/{testResult.total}</strong>
            <div className="muted">Submission saved in demo memory.</div>
          </div>}
        </>}
      </div>}
    </div>

    <div className="footer">
      Demo build for ${CONFIG.instituteName}. Replace placeholder details, then connect MySQL and proper auth for production.
    </div>
  </div>;
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
</html>`;

app.get('/', (req, res) => res.type('html').send(html));

app.listen(PORT, () => {
  console.log(`Demo app running at http://localhost:${PORT}`);
});
