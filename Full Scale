});

app.get('/api/admin/students', auth, requireRole('admin'), (req, res) => {
  res.json({ students: db.students, submissions: db.submissions, receipts: db.receipts, uploads });
});

app.post('/api/admin/student', auth, requireRole('admin'), (req, res) => {
  const { name, course, batch, phone, email } = req.body;
  const id = Date.now();
  db.students.push({
    id,
    name,
    course,
    batch,
    phone,
    email,
    feesStatus: 'Pending',
    progress: 0,
  });
  res.json({ ok: true, studentId: id });
});

app.patch('/api/admin/student/:id', auth, requireRole('admin'), (req, res) => {
  const student = db.students.find((s) => String(s.id) === String(req.params.id));
  if (!student) return res.status(404).json({ error: 'Student not found' });
  Object.assign(student, req.body);
  res.json({ ok: true, student });
});

app.post('/api/admin/receipt', auth, requireRole('admin'), (req, res) => {
  const { studentName, amount, mode, note } = req.body;
  const receipt = {
    id: Date.now(),
    receiptNo: `RCPT-${Date.now()}`,
    studentName,
    amount,
    mode,
    note,
    date: new Date().toISOString().slice(0, 10),
  };
  db.receipts.push(receipt);
  res.json({ ok: true, receipt });
});

app.get('/api/test', auth, (req, res) => {
  res.json({ questions: db.testQuestions });
});

app.post('/api/test/submit', auth, (req, res) => {
  const { answers } = req.body;
  let score = 0;
  const details = db.testQuestions.map((q) => {
    const userAns = answers?.[q.id];
    let correct = false;

    if (q.type === 'mcq') {
      correct = Number(userAns) === q.answer;
    } else if (q.type === 'numeric') {
      correct = Number(userAns) === Number(q.answer);
    }

    if (correct) score += 1;
    return { id: q.id, correct, userAns };
  });

  const submission = {
    id: Date.now(),
    userId: req.user.id,
    userEmail: req.user.email,
    score,
    total: db.testQuestions.length,
    details,
    submittedAt: new Date().toISOString(),
  };
  db.submissions.push(submission);
  res.json({ ok: true, score, total: db.testQuestions.length, submission });
});

app.post('/api/upload', auth, upload.single('file'), (req, res) => {
  if (!req.file) return res.status(400).json({ error: 'No file uploaded' });
  const record = {
    id: Date.now(),
    userEmail: req.user.email,
    originalName: req.file.originalname,
    mimeType: req.file.mimetype,
    size: req.file.size,
    uploadedAt: new Date().toISOString(),
  };
  uploads.push(record);
  res.json({ ok: true, file: record });
});

